# =============================================================================
# WAF Console — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before starting the server.
#
#   cp .env.example .env
#   nano .env          # Edit with your settings
#   docker-compose -f docker-compose.prod.yml up -d
#
# Lines starting with # are comments. Remove # to activate a setting.
# =============================================================================


# =============================================================================
# CORE SERVER
# =============================================================================

# Runtime environment. Always set to 'production' on live servers.
NODE_ENV=production

# Port for the Analyst Console (WAF admin dashboard — keep this INTERNAL only)
DASHBOARD_PORT=3000

# Port for the Client Console (site-owner view — can be public-facing)
CLIENT_PORT=3001

# Port the WAF reverse proxy listens on for HTTP traffic
PROXY_PORT=8080

# Port the WAF reverse proxy listens on for HTTPS traffic
HTTPS_PROXY_PORT=8443

# Network interface to bind to. Use 0.0.0.0 for all interfaces.
BIND_ADDRESS=0.0.0.0

# Default WAF enforcement mode for new sites
# BLOCKING = inspect and block malicious requests (recommended for production)
# DETECTION = inspect only, log but never block (use during initial setup)
WAF_MODE=BLOCKING

# Default backend URL when no site-specific routing is configured.
# The WAF will forward clean traffic here.
DEFAULT_BACKEND=http://your-backend-server:80


# =============================================================================
# SECURITY SECRETS
# =============================================================================
# IMPORTANT: These are auto-generated on first boot and saved to data/.secrets.json
# You do NOT need to set them manually unless you want to rotate secrets.
# If set here, they override the auto-generated values.

# Cookie signing secret. Must be at least 32 random characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# SESSION_SECRET=

# Initial admin account password. Only used on first boot if no users exist.
# After first login, change your password via the UI.
# DEFAULT_ADMIN_USER=admin
# DEFAULT_ADMIN_PASS=

# CSRF protection secret. Auto-generated if not set.
# CSRF_SECRET=


# =============================================================================
# DATABASE
# =============================================================================

# Database driver: 'sqlite' (default, zero-config) or 'postgres' (production scale)
DB_DRIVER=sqlite

# SQLite database file path (only used when DB_DRIVER=sqlite)
DB_PATH=/app/data/waf_events.db

# Maximum number of events to retain in the database (auto-purges oldest)
MAX_EVENTS=100000

# --- PostgreSQL settings (only used when DB_DRIVER=postgres) ---
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_DATABASE=waf_production
# PG_USER=waf
# PG_PASSWORD=change-this-strong-password


# =============================================================================
# REDIS (OPTIONAL — enables PM2 cluster mode and cross-worker session sharing)
# =============================================================================
# Remove the # and fill in your Redis URL to enable clustering.
# Without Redis, the WAF runs in single-process mode (fine for most SMBs).
#
# REDIS_URL=redis://localhost:6379
# With auth: REDIS_URL=redis://:yourpassword@localhost:6379


# =============================================================================
# TLS / HTTPS
# =============================================================================

# Path to your TLS certificate (PEM format, full chain)
TLS_CERT_PATH=/app/data/certs/fullchain.pem

# Path to your TLS private key (PEM format)
TLS_KEY_PATH=/app/data/certs/privkey.pem

# --- Let's Encrypt Auto-SSL (ACME) ---
# Set ACME_ENABLED=true and provide your email to automatically obtain and
# renew a free TLS certificate. Port 80 must be publicly accessible.
ACME_ENABLED=false
# ACME_EMAIL=admin@yourdomain.com


# =============================================================================
# THREAT INTELLIGENCE (OPTIONAL)
# =============================================================================

# AbuseIPDB API key for real-time IP reputation checks.
# Get a free key at: https://www.abuseipdb.com/api
# ABUSEIPDB_API_KEY=

# AlienVault OTX API key for Open Threat Exchange feeds.
# Get a free key at: https://otx.alienvault.com/api
# OTX_API_KEY=

# How often (in hours) to refresh external threat intelligence feeds
THREAT_INTEL_REFRESH_HOURS=6


# =============================================================================
# GEOIP (OPTIONAL — improves geo-blocking accuracy)
# =============================================================================
# The WAF uses a built-in IP database by default.
# For higher accuracy, download the free MaxMind GeoLite2 database:
#   1. Register at https://www.maxmind.com/en/geolite2/signup
#   2. Download GeoLite2-Country.mmdb
#   3. Place it at the path below (inside your data volume)
#
MAXMIND_DB_PATH=/app/data/GeoLite2-Country.mmdb
# MAXMIND_LICENSE_KEY=  (for auto-download in future versions)


# =============================================================================
# NOTIFICATIONS & ALERTING
# =============================================================================

# --- Email Alerts (SMTP) ---
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=waf-alerts@yourdomain.com
# ALERT_EMAIL_TO=security@yourdomain.com

# --- Webhook Alerts (Slack / Microsoft Teams / Generic) ---
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# WEBHOOK_FORMAT=slack   # Options: slack, teams, generic


# =============================================================================
# SIEM INTEGRATION (OPTIONAL)
# =============================================================================

# Forward events to a syslog server (UDP)
# SIEM_SYSLOG_HOST=your-siem-host.internal
# SIEM_SYSLOG_PORT=514

# Forward events to a webhook endpoint (Splunk HEC, Elastic, etc.)
# SIEM_WEBHOOK_URL=https://your-siem-endpoint/api/events
# SIEM_FORMAT=json   # Options: json, cef (Common Event Format)


# =============================================================================
# LICENSING
# =============================================================================

# Your WAF Console license key. Leave empty to run in demo mode (5 sites max).
# Contact your vendor or use: node license.js generate "Your Company" 50 2027-12-31
# LICENSE_KEY=


# =============================================================================
# LOGGING
# =============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info
